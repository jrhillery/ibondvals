<project xmlns="http://maven.apache.org/POM/4.0.0">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.leastlogic</groupId>
        <artifactId>MdProjects</artifactId>
        <version>1-SNAPSHOT</version>
        <relativePath>../mdutil/MdProjects</relativePath>
    </parent>

    <artifactId>ibondvalues</artifactId>
    <name>I Bond Values</name>
    <description>
        Pulls I bond interest rates from TreasuryDirect.gov and creates artificial interest transactions in Moneydance.
    </description>
    <url>https://github.com/jrhillery/ibondvals</url>

    <dependencies>
        <dependency>
            <groupId>org.dhatim</groupId>
            <artifactId>fastexcel-reader</artifactId>
            <version>0.20.0</version>
        </dependency>
        <dependency>
            <groupId>com.leastlogic</groupId>
            <artifactId>md-util</artifactId>
            <version>1-SNAPSHOT</version>
        </dependency>
        <dependency>
            <groupId>com.leastlogic</groupId>
            <artifactId>swing-util</artifactId>
            <version>1-SNAPSHOT</version>
        </dependency>
        <dependency>
            <groupId>org.jetbrains.kotlin</groupId>
            <artifactId>kotlin-stdlib</artifactId> <!-- seem to need this -->
            <version>1.9.23</version>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.6.2</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <outputFile>
                                ${project.build.directory}/${project.artifactId}-${project.version}.mxt
                            </outputFile>
                            <minimizeJar>true</minimizeJar>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
